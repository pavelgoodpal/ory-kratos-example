version: v1.3.1

# DSN is supplied via the DSN environment variable in docker-compose.

serve:
  public:
    base_url: ${KRATOS_BROWSER_URL}/
    cors:
      enabled: true
      allowed_origins:
${CORS_ORIGINS_YAML}
      allowed_methods:
        - POST
        - GET
        - PUT
        - PATCH
        - DELETE
      allowed_headers:
        - Authorization
        - Cookie
        - Content-Type
        - X-Session-Token
      exposed_headers:
        - Content-Type
        - Set-Cookie
      allow_credentials: true
  admin:
    base_url: http://kratos:4434/

selfservice:
  default_browser_return_url: ${CLIENT_ORIGIN}/
  allowed_return_urls:
${RETURN_URLS_YAML}

  methods:
    # Email + password as the first factor, plus a one-time email CODE as a
    # required second factor (MFA). Social sign-in (oidc) is disabled.
    password:
      enabled: true
      config:
        haveibeenpwned_enabled: false
        min_password_length: 8
    code:
      enabled: true
      config:
        lifespan: 15m
      # The code is NOT a passwordless login method here; it is the second
      # factor (AAL2) emailed on every login.
      passwordless_enabled: false
      mfa_enabled: true
    link:
      enabled: false
    oidc:
      enabled: false

  flows:
    error:
      ui_url: ${CLIENT_ORIGIN}/error

    settings:
      ui_url: ${CLIENT_ORIGIN}/settings
      privileged_session_max_age: 15m
      required_aal: highest_available

    # Email one-time-code recovery (reset password) and verification.
    recovery:
      enabled: true
      ui_url: ${CLIENT_ORIGIN}/recovery
      use: code

    verification:
      enabled: true
      ui_url: ${CLIENT_ORIGIN}/verification
      use: code
      after:
        default_browser_return_url: ${CLIENT_ORIGIN}/login

    logout:
      after:
        default_browser_return_url: ${CLIENT_ORIGIN}/login

    login:
      ui_url: ${CLIENT_ORIGIN}/login
      lifespan: 10m

    registration:
      lifespan: 10m
      ui_url: ${CLIENT_ORIGIN}/registration
      after:
        password:
          hooks:
            # No `session` hook: after registering, the user verifies their
            # email (OTP) and then logs in with password + the emailed code.
            - hook: show_verification_ui

log:
  level: info
  format: text
  leak_sensitive_values: false

secrets:
  cookie:
    - ${KRATOS_COOKIE_SECRET}
  cipher:
    - ${KRATOS_CIPHER_SECRET}

ciphers:
  algorithm: xchacha20-poly1305

hashers:
  algorithm: bcrypt
  bcrypt:
    cost: 8

identity:
  default_schema_id: default
  schemas:
    - id: default
      url: file:///etc/config/kratos/identity.schema.json

courier:
  smtp:
    connection_uri: smtp://${SMTP_USER_ENC}:${SMTP_PASS}@${SMTP_HOST}:${SMTP_PORT}/
    from_address: ${SMTP_FROM}
    from_name: ${SMTP_FROM_NAME}

session:
  lifespan: 720h
  cookie:
    same_site: Lax
  whoami:
    # Require the highest assurance the identity supports. With email-code MFA
    # enabled and a verified email, that is AAL2 — so a password-only (AAL1)
    # session is not considered fully authenticated until the emailed code is
    # entered. This is what forces the OTP second factor on every login.
    required_aal: highest_available
