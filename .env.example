# Copy to .env and fill in real values.

# --- Social sign-in (OIDC) -------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# --- App origins / ports ---------------------------------------------------
CLIENT_ORIGIN=http://localhost:3000
# Comma-separated list of all origins Kratos accepts (CORS + return URLs).
CLIENT_ORIGINS=http://localhost:3000
PORT=4000
KRATOS_PUBLIC_URL=http://localhost:4433
KRATOS_BROWSER_URL=http://localhost:4433

# --- SMTP (leave blank to print codes to kratos logs) ----------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME='Car Store'

# --- Primary car owner (seeded on startup; owns all cars initially) --------
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me-12345

# --- Postgres --------------------------------------------------------------
POSTGRES_USER=kratos
POSTGRES_PASSWORD=kratos_secret
POSTGRES_DB=kratos

# --- Kratos secrets (must be >= 16 chars) ----------------------------------
KRATOS_COOKIE_SECRET=change-me-please-0001
KRATOS_CIPHER_SECRET=change-me-please-0002
